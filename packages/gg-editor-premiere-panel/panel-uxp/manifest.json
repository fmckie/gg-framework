{
  "id": "com.kenkaiiii.gg-editor-premiere-panel.uxp",
  "name": "GG Editor",
  "version": "0.2.0",
  "main": "index.html",
  "manifestVersion": 5,
  "host": [
    {
      "app": "premierepro",
      "minVersion": "25.6.0"
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "ggeditor.panel",
      "label": {
        "default": "GG Editor"
      },
      "minimumSize": { "width": 280, "height": 220 },
      "preferredDockedSize": { "width": 320, "height": 260 },
      "preferredFloatingSize": { "width": 360, "height": 280 }
    }
  ],
  "requiredPermissions": {
    "network": {
      "domains": [
        "ws://127.0.0.1:7437",
        "ws://127.0.0.1:7438",
        "ws://127.0.0.1:7439",
        "ws://127.0.0.1:7440",
        "ws://127.0.0.1:7441",
        "ws://127.0.0.1:7442",
        "ws://127.0.0.1:7443",
        "ws://localhost:7437",
        "ws://localhost:7438",
        "ws://localhost:7439",
        "ws://localhost:7440",
        "ws://localhost:7441",
        "ws://localhost:7442",
        "ws://localhost:7443"
      ]
    }
  },
  "icons": []
}
