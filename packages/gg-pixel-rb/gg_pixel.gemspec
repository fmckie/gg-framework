Gem::Specification.new do |s|
  s.name        = "gg_pixel"
  s.version     = "4.3.72"
  s.summary     = "Universal error tracking pixel — Ruby SDK"
  s.description = "Drop-in error tracking optimized for autonomous coding agents. Same wire format as the Node, Browser, Python, Rust, Swift, and Go SDKs."
  s.authors     = ["Ken Kai"]
  s.license     = "MIT"
  s.files       = Dir["lib/**/*.rb"] + ["README.md"]
  s.required_ruby_version = ">= 2.6.0"
  s.homepage    = "https://github.com/kenkaiiii/gg-framework"
  s.metadata    = { "source_code_uri" => "https://github.com/kenkaiiii/gg-framework" }
end
