{
  "name": "@kleio/manager",
  "version": "4.10.1-kleio.0",
  "type": "module",
  "description": "Kleio Manager orchestrates multiple Kleio Coder workers across projects from one chat",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fmckie/gg-framework.git",
    "directory": "packages/gg-boss"
  },
  "bin": {
    "kleio-manager": "./dist/cli.js",
    "ggboss": "./dist/cli.js"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && cp -R assets/. dist/ && chmod +x dist/cli.js",
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@kleio/agent": "workspace:*",
    "@kleio/ai": "workspace:*",
    "@kleio/core": "workspace:*",
    "@kleio/coder": "workspace:*",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "chalk": "^5.6.2",
    "ink": "npm:@kenkaiiii/ink@6.8.0-gg.2",
    "react": "^19.2.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.6.0",
    "ogg-opus-decoder": "^1.6.13"
  },
  "publishConfig": {
    "access": "public"
  }
}
